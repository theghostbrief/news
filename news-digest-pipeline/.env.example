# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=https://news.questtales.com
DB_PATH=./data/news-digest.db

# ─── Auth (dashboard + API) ──────────────────────────────────────────────────
API_SECRET_KEY=change-me-to-a-strong-random-key
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# ─── LLM (vendor + model) ────────────────────────────────────────────────────
# LLM_VENDOR selects which API receives requests: anthropic | openai.
# CLAUDE_MODEL holds the active model id for the selected vendor (historical name;
# it is vendor-agnostic — put an OpenAI id here when LLM_VENDOR=openai).
LLM_VENDOR=anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

ANTHROPIC_API_KEY=sk-ant-...
# Leave *_BASE_URL empty to use the vendor default endpoint.
ANTHROPIC_BASE_URL=

OPENAI_API_KEY=
OPENAI_BASE_URL=
# Reasoning depth for the OpenAI path only. Leave EMPTY to send nothing
# (current default). Suggested values: minimal | low | medium | high.
# An unsupported value is dropped automatically at runtime and retried.
OPENAI_REASONING_EFFORT=

# ─── Queue & generation ──────────────────────────────────────────────────────
ARTICLE_THRESHOLD=13
MAX_ARTICLES_PER_DIGEST=17
CHECK_INTERVAL_MS=60000
# Active Phase-A scenario: sarcastic (prompt.md) | architect (prompt_deep.md).
ACTIVE_SCENARIO=sarcastic

# ─── Notifications ───────────────────────────────────────────────────────────
NTFY_TOPIC=news-digest-alexkrol

# ─── Publishing: Facebook Page (only Page is supported — no personal profile) ─
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ─── Publishing: Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Channel the digest is published to (falls back to TELEGRAM_CHAT_ID if unset).
TELEGRAM_PUBLISH_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─── Media generation (optional) ─────────────────────────────────────────────
FAL_KEY=

# ─── Planned integrations (status-only stubs — pipelines not implemented) ─────
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
GEMINI_API_KEY=
